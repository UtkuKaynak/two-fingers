{
  "name": "two-fingers",
  "displayName": "two-fingers",
  "description": "Chrome-style pinch / scroll zoom for VS Code editors and webviews (patches the workbench).",
  "version": "0.1.2",
  "publisher": "utkukaynak",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/UtkuKaynak/two-fingers" },
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "two-fingers.enable", "title": "two-fingers: Enable (patch + reload)" },
      { "command": "two-fingers.disable", "title": "two-fingers: Disable (unpatch + reload)" },
      { "command": "two-fingers.reapply", "title": "two-fingers: Reapply patch" }
    ]
  },
  "scripts": {
    "build": "node build.js",
    "package": "npm run build && npx --yes @vscode/vsce package"
  }
}
